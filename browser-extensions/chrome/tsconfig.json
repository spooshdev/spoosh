{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "declaration": false,
    "declarationMap": false,
    "types": ["chrome"],
    "paths": {
      "@devtool/*": ["../../packages/devtool/src/*"],
      "@spoosh/core": ["../../packages/core/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../../packages/devtool/src/**/*.ts",
    "../../packages/core/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../../packages/core/src/**/*.test.ts",
    "../../packages/devtool/src/**/*.test.ts"
  ]
}
