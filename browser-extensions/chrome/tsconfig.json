{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "declaration": false,
    "declarationMap": false,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "types": ["chrome"],
    "paths": {
      "@devtool/*": ["../../packages/devtool/src/*"],
      "@spoosh/core": ["../../packages/core/src/index.ts"],
      "@panel/*": ["./src/panel/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../packages/devtool/src/**/*.ts",
    "../../packages/core/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../../packages/core/src/**/*.test.ts",
    "../../packages/devtool/src/**/*.test.ts"
  ]
}
