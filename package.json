{
  "name": "spoosh-monorepo",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "turbo run build --filter='./packages/*'",
    "dev": "turbo run dev --filter='./packages/*' --concurrency=30",
    "dev:docs": "pnpm --filter @spoosh/docs dev",
    "build:docs": "pnpm --filter @spoosh/docs build",
    "typecheck": "turbo run typecheck --filter='./packages/*'",
    "test:types": "turbo run test:types --filter='./type-tests/*'",
    "lint": "turbo run lint --filter='./packages/*'",
    "format": "turbo run format //#format:root --filter='./packages/*' --filter='./examples/*' --filter='./docs' --filter='./type-tests/*'",
    "format:root": "prettier --write '*.md'",
    "changeset": "changeset",
    "bump": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.1.0",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/expect": "^4.0.17",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "tsup": "^8.5.1",
    "turbo": "^2.8.10",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.0.17"
  }
}
